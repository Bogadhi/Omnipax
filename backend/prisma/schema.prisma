generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                  String              @id @default(uuid())
  slug                String              @unique
  name                String
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  platformFeeEnabled  Boolean             @default(false)
  platformFeeType     PlatformFeeType     @default(PERCENTAGE)
  platformFeeValue    Decimal             @default(0) @db.Decimal(10, 2)
  billingEmail        String?
  bookingLimit        Int                 @default(100)
  monthlyBookingCount Int                 @default(0)
  monthlyRevenue      Decimal             @default(0) @db.Decimal(10, 2)
  plan                String              @default("FREE")
  status              String              @default("ACTIVE")
  subscriptionStatus  String              @default("TRIALING")
  trialEndsAt         DateTime?
  bookings            Booking[]
  bookingSeats        BookingSeat[]
  coupons             Coupon[]
  events              Event[]
  giftCards           GiftCard[]
  monetizationAudits  MonetizationAudit[]
  screens             Screen[]
  seats               Seat[]
  seatAvailability    SeatAvailability[]
  seatLocks           SeatLock[]
  shows               Show[]
  theaters            Theater[]
  users               User[]
  wishlists           Wishlist[]
}

model User {
  id                   String               @id @default(uuid())
  email                String               @unique
  password             String
  name                 String?
  role                 Role                 @default(USER)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  tenantId             String?
  forcePasswordReset   Boolean              @default(false)
  theaterId            String?
  isVerified           Boolean              @default(false)
  otp                  String?
  otpExpiry            DateTime?
  auditLogs            AuditLog[]
  bookings             Booking[]
  reviewedApplications TheaterApplication[] @relation("Reviewer")
  tenant               Tenant?              @relation(fields: [tenantId], references: [id])
  theater              Theater?             @relation(fields: [theaterId], references: [id])
  wishlists            Wishlist[]

  @@index([email])
  @@index([role])
  @@index([tenantId])
  @@index([theaterId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  actorRole String?
  after     Json?
  before    Json?
  entity    String?
  tenantId  String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([createdAt])
}

model FeatureFlag {
  id        String   @id @default(uuid())
  key       String
  enabled   Boolean  @default(false)
  tenantId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, tenantId])
  @@index([tenantId])
}

model RazorpayWebhookEvent {
  id        String   @id @default(uuid())
  eventId   String   @unique
  createdAt DateTime @default(now())
}

model Theater {
  id       String   @id @default(uuid())
  name     String
  city     String
  address  String
  tenantId String?
  screens  Screen[]
  tenant   Tenant?  @relation(fields: [tenantId], references: [id])
  users    User[]

  @@index([tenantId])
}

model Screen {
  id          String  @id @default(uuid())
  name        String
  totalRows   Int
  seatsPerRow Int
  theaterId   String
  tenantId    String?
  tenant      Tenant? @relation(fields: [tenantId], references: [id])
  theater     Theater @relation(fields: [theaterId], references: [id])
  seats       Seat[]
  shows       Show[]

  @@index([tenantId])
}

model Event {
  id             String     @id @default(uuid())
  title          String
  type           EventType
  language       String
  duration       Int
  posterUrl      String?
  bannerUrl      String?
  description    String?
  date           DateTime
  location       String
  price          Float
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  totalSeats     Int        @default(0)
  availableSeats Int        @default(0)
  isActive       Boolean    @default(true)
  tenantId       String?
  bookings       Booking[]
  tenant         Tenant?    @relation(fields: [tenantId], references: [id])
  shows          Show[]
  wishlists      Wishlist[]

  @@index([date])
  @@index([tenantId])
}

model Show {
  id                String             @id @default(uuid())
  startTime         DateTime
  price             Float
  isActive          Boolean            @default(true)
  totalCapacity     Int                @default(0)
  remainingCapacity Int                @default(0)
  eventId           String
  screenId          String
  tenantId          String?
  bookings          Booking[]
  seatAvailability  SeatAvailability[]
  event             Event              @relation(fields: [eventId], references: [id])
  screen            Screen             @relation(fields: [screenId], references: [id])
  tenant            Tenant?            @relation(fields: [tenantId], references: [id])

  @@index([isActive])
  @@index([screenId, startTime])
  @@index([startTime])
  @@index([tenantId])
}

model Seat {
  id           String             @id @default(uuid())
  screenId     String
  row          String
  number       Int
  tenantId     String?
  bookingSeats BookingSeat[]
  screen       Screen             @relation(fields: [screenId], references: [id])
  tenant       Tenant?            @relation(fields: [tenantId], references: [id])
  availability SeatAvailability[]

  @@index([tenantId])
}

model SeatAvailability {
  id          String     @id @default(uuid())
  showId      String
  seatId      String
  status      SeatStatus @default(AVAILABLE)
  lockedUntil DateTime?
  userId      String?
  tenantId    String?
  seat        Seat       @relation(fields: [seatId], references: [id])
  show        Show       @relation(fields: [showId], references: [id])
  tenant      Tenant?    @relation(fields: [tenantId], references: [id])

  @@unique([showId, seatId])
  @@index([showId, status])
  @@index([showId, status, lockedUntil])
  @@index([tenantId])
}

model SeatLock {
  id         String   @id @default(uuid())
  showId     String
  seatNumber String
  userId     String
  bookingId  String
  expiresAt  DateTime
  status     String
  createdAt  DateTime @default(now())
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([showId, tenantId])
  @@index([expiresAt])
}

model Booking {
  id                            String           @id @default(uuid())
  userId                        String
  showId                        String
  totalAmount                   Decimal          @db.Decimal(10, 2)
  status                        BookingStatus    @default(PENDING)
  paymentId                     String?          @unique
  expiresAt                     DateTime?
  createdAt                     DateTime         @default(now())
  cancelledAt                   DateTime?
  refundedAt                    DateTime?
  scannedAt                     DateTime?
  validatedBy                   String?
  qrToken                       String?          @unique
  basePrice                     Float            @default(0)
  convenienceFee                Float            @default(0)
  razorpayOrderId               String?          @unique
  razorpayPaymentId             String?          @unique
  razorpaySignature             String?
  razorpayRefundId              String?          @unique
  discountAmount                Decimal          @default(0) @db.Decimal(10, 2)
  couponDiscountAmount          Decimal          @default(0) @db.Decimal(10, 2)
  giftCardDiscountAmount        Decimal          @default(0) @db.Decimal(10, 2)
  finalAmount                   Decimal          @default(0) @db.Decimal(10, 2)
  couponId                      String?
  giftCardId                    String?
  eventId                       String?
  tenantId                      String?
  lockedUntil                   DateTime?
  orderId                       String?          @unique
  paymentCapturedAt             DateTime?
  refundCompletedAt             DateTime?
  refundInitiatedAt             DateTime?
  platformFeeAmount             Decimal          @default(0) @db.Decimal(10, 2)
  ticketAmount                  Decimal          @default(0) @db.Decimal(10, 2)
  platformFeePercentageSnapshot Decimal?         @db.Decimal(10, 2)
  platformFeeTypeSnapshot       PlatformFeeType?
  platformFlatFeeSnapshot       Decimal?         @db.Decimal(10, 2)
  refundAmount                  Decimal          @default(0) @db.Decimal(10, 2)
  refundedSeatsCount            Int              @default(0)
  theaterNetAmount              Decimal          @default(0) @db.Decimal(10, 2)
  coupon                        Coupon?          @relation(fields: [couponId], references: [id])
  event                         Event?           @relation(fields: [eventId], references: [id])
  giftCard                      GiftCard?        @relation(fields: [giftCardId], references: [id])
  show                          Show             @relation(fields: [showId], references: [id])
  tenant                        Tenant?          @relation(fields: [tenantId], references: [id])
  user                          User             @relation(fields: [userId], references: [id])
  bookingSeats                  BookingSeat[]

  @@index([status, createdAt])
  @@index([userId, status])
  @@index([tenantId])
}

model BookingSeat {
  id        String         @id @default(uuid())
  bookingId String
  seatId    String
  showId    String?
  price     Float
  status    BookingStatus?
  tenantId  String?
  booking   Booking        @relation(fields: [bookingId], references: [id])
  seat      Seat           @relation(fields: [seatId], references: [id])
  tenant    Tenant?        @relation(fields: [tenantId], references: [id])

  @@index([bookingId])
  @@index([seatId, status])
  @@index([tenantId])
}

model SystemEventLog {
  id        String   @id @default(uuid())
  eventType String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  tenantId  String?
  event     Event    @relation(fields: [eventId], references: [id])
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, eventId])
  @@index([userId])
  @@index([tenantId])
}

model Coupon {
  id             String       @id @default(uuid())
  code           String       @unique
  description    String?
  discountType   DiscountType
  discountValue  Float
  minOrderAmount Float        @default(0)
  maxDiscount    Float?
  usageLimit     Int?
  usageCount     Int          @default(0)
  isActive       Boolean      @default(true)
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  tenantId       String?
  bookings       Booking[]
  tenant         Tenant?      @relation(fields: [tenantId], references: [id])

  @@index([code])
  @@index([isActive, expiresAt])
  @@index([tenantId])
}

model GiftCard {
  id        String    @id @default(uuid())
  code      String    @unique
  balance   Float
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  tenantId  String?
  bookings  Booking[]
  tenant    Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([code])
  @@index([tenantId])
}

model PaymentEvent {
  id              String    @id @default(uuid())
  razorpayEventId String    @unique
  bookingId       String?
  eventType       String
  payload         Json
  processed       Boolean   @default(false)
  tenantId        String
  createdAt       DateTime  @default(now())
  errorMessage    String?
  failedAt        DateTime?
  isDeadLetter    Boolean   @default(false)
  retryCount      Int       @default(0)

  @@index([bookingId])
  @@index([tenantId])
  @@index([isDeadLetter])
  @@index([processed, createdAt])
}

model PaymentLedger {
  id         String   @id @default(uuid())
  bookingId  String
  amount     Int
  currency   String
  type       String
  razorpayId String
  status     String
  tenantId   String
  createdAt  DateTime @default(now())

  @@index([bookingId])
  @@index([tenantId])
}

model DeadLetterEvent {
  id              String   @id @default(uuid())
  type            String
  payload         Json
  reason          String
  bookingId       String?
  razorpayEventId String?
  retryCount      Int      @default(0)
  tenantId        String
  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([bookingId])
}

model Ticket {
  id         String    @id @default(uuid())
  bookingId  String
  showId     String
  seatNumber String
  qrHash     String    @unique
  status     String
  scannedAt  DateTime?
  scannedBy  String?
  tenantId   String
  createdAt  DateTime  @default(now())

  @@index([bookingId])
  @@index([showId])
  @@index([tenantId])
}

model TicketScanLog {
  id         String   @id @default(uuid())
  ticketId   String
  scannedBy  String
  deviceId   String?
  result     String
  tenantId   String
  createdAt  DateTime @default(now())
  scanSource String   @default("STAFF")

  @@index([ticketId])
  @@index([tenantId])
}

model ScannerDevice {
  id         String    @id @default(uuid())
  name       String
  deviceKey  String    @unique
  isActive   Boolean   @default(true)
  tenantId   String
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
}

model OfflineScanQueue {
  id        String   @id @default(uuid())
  ticketId  String
  deviceId  String
  scannedAt DateTime
  synced    Boolean  @default(false)
  result    String?
  tenantId  String
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([deviceId])
  @@index([tenantId])
}

model MonetizationAudit {
  id              String           @id @default(uuid())
  tenantId        String
  oldFeeType      PlatformFeeType?
  oldPercentage   Decimal?         @db.Decimal(10, 2)
  oldFlatFee      Decimal?         @db.Decimal(10, 2)
  newFeeType      PlatformFeeType
  newPercentage   Decimal?         @db.Decimal(10, 2)
  newFlatFee      Decimal?         @db.Decimal(10, 2)
  changedByUserId String
  createdAt       DateTime         @default(now())
  tenant          Tenant           @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model TheaterApplication {
  id           String                @id @default(uuid())
  theaterName  String
  theaterSlug  String
  ownerName    String
  email        String
  phone        String
  address      String
  city         String
  state        String
  gstNumber    String?
  status       ApplicationStatus     @default(PENDING)
  reviewNotes  String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  documents    ApplicationDocument[]
  reviewedBy   User?                 @relation("Reviewer", fields: [reviewedById], references: [id])

  @@unique([email, status])
  @@index([email])
  @@index([theaterName])
  @@index([status])
  @@index([theaterSlug])
}

model ApplicationDocument {
  id            String             @id @default(uuid())
  applicationId String
  documentType  DocumentType
  fileUrl       String
  createdAt     DateTime           @default(now())
  application   TheaterApplication @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
}

model PaymentLog {
  id                String   @id @default(uuid())
  bookingId         String
  razorpayOrderId   String
  razorpayPaymentId String   @unique
  verified          Boolean  @default(false)
  amount            Float
  status            String
  rawPayload        Json
  tenantId          String
  createdAt         DateTime @default(now())

  @@index([bookingId])
  @@index([razorpayOrderId])
  @@index([tenantId])
}

enum EventType {
  MOVIE
  CONCERT
  EVENT
  GENERAL_ADMISSION
}

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  THEATER_MANAGER
  STAFF
  USER
  ADMIN
  SCANNER_DEVICE
}

enum BookingStatus {
  PENDING
  LOCKED
  PAYMENT_IN_PROGRESS
  CONFIRMED
  FAILED
  EXPIRED
  CANCELLED
  REFUND_INITIATED
  REFUNDED
  REFUND_FAILED
}

enum SeatStatus {
  AVAILABLE
  LOCKED
  BOOKED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PlatformFeeType {
  PERCENTAGE
  FLAT
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  GST
  LICENSE
  ID_PROOF
}
